---
import { getAllPosts, getUniqueTagsWithCount } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import { getTagEmoji } from "@/config/tag-emoji";

const allPosts = await getAllPosts();
const allTags = getUniqueTagsWithCount(allPosts);

const meta = {
	description: "A list of all the topics I've written about in my posts",
	title: "All Tags",
};
---

<PageLayout meta={meta}>
	<h1 class="title mb-6">Tags</h1>
	<ul class="space-y-4">
		{
			allTags.map(([tag, val]) => {
				const emoji = getTagEmoji(tag);
				return (
					<li class="flex items-center gap-x-2">
						<a
							class="cactus-link inline-block"
							href={`/tags/${tag}/`}
							title={`View posts with the tag: ${tag}`}
						>
							<span aria-hidden="true">&#35;</span>
							{emoji && (
								<span aria-hidden="true" class="ms-1">
									{emoji}
								</span>
							)}
							<span class="ms-1">{tag}</span>
						</a>
						<span class="inline-block">
							- {val} Post{val > 1 && "s"}
						</span>
					</li>
				);
			})
		}
	</ul>
</PageLayout>
