---
import { type CollectionEntry, getCollection, render } from "astro:content";
import BackToPrevious from "@components/BackToPrevious.astro";
import Container from "@components/Container.astro";
import FormattedDate from "@components/FormattedDate.astro";
import Link from "@components/Link.astro";
import TableOfContents from "@components/TableOfContents.astro";
import Layout from "@layouts/Layout.astro";
import { readingTime } from "@lib/utils";

export async function getStaticPaths() {
  const showDrafts = import.meta.env.DEV;
  const projects = (await getCollection("projects"))
    .filter((post) => showDrafts || !post.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return projects.map((project) => ({
    params: { id: project.id },
    props: project,
  }));
}
type Props = CollectionEntry<"projects">;

const project = Astro.props;
const { Content, headings } = await render(project);
---

<Layout
  title={project.data.title}
  description={project.data.description}
  image={project.data.ogImage ?? `/og-image/projects/${project.id}.png`}
>
  <Container>
    <div class="animate">
      <BackToPrevious href="/projects">Back to projects</BackToPrevious>
    </div>
    <div class="animate mx-auto my-10 max-w-5xl space-y-1">
      <div class="flex items-center gap-1.5">
        <div class="font-base text-sm">
          <FormattedDate date={project.data.date} />
        </div>
        &bull;
        {
          project.body && (
            <div class="font-base text-sm">{readingTime(project.body)}</div>
          )
        }
      </div>
      <h1 class="text-3xl font-semibold text-black dark:text-white">
        {project.data.title}
      </h1>
      {
        (project.data.demoURL || project.data.repoURL) && (
          <nav class="flex gap-1">
            {project.data.demoURL && (
              <Link href={project.data.demoURL} external>
                demo
              </Link>
            )}
            {project.data.demoURL && project.data.repoURL && <span>/</span>}
            {project.data.repoURL && (
              <Link href={project.data.repoURL} external>
                repo
              </Link>
            )}
          </nav>
        )
      }
    </div>
    <div class="relative">
      {
        headings.length > 0 && (
          <aside class="mx-auto mb-8 max-w-5xl 2xl:fixed 2xl:top-28 2xl:bottom-40 2xl:left-[calc(50%+34rem)] 2xl:mb-0 2xl:w-56 2xl:max-w-none">
            <TableOfContents headings={headings} />
          </aside>
        )
      }
      <article class="animate mx-auto max-w-5xl min-w-0">
        <Content />
      </article>
    </div>
  </Container>
</Layout>
