---
import { type CollectionEntry, getCollection, render } from "astro:content";
import BackToPrevious from "@components/BackToPrevious.astro";
import Container from "@components/Container.astro";
import EntryBadges from "@components/EntryBadges.astro";
import FormattedDate from "@components/FormattedDate.astro";
import Link from "@components/Link.astro";
import OgImage from "@components/OgImage.astro";
import TableOfContents from "@components/TableOfContents.astro";
import { SITE } from "@consts";
import { isVisibleEntry, sortByDateDesc } from "@lib/content-sort";
import Layout from "@layouts/Layout.astro";
import { readingTime } from "@lib/utils";

export async function getStaticPaths() {
  const projects = sortByDateDesc(
    (await getCollection("projects")).filter(isVisibleEntry),
  );
  return projects.map((project) => ({
    params: { id: project.id },
    props: project,
  }));
}
type Props = CollectionEntry<"projects">;

const project = Astro.props;
const { Content, headings } = await render(project);
const ogImageVersion = "20260614-og-background";
---

<Layout
  title={project.data.title}
  description={project.data.description ?? SITE.DESCRIPTION}
  image={project.data.ogImage ??
    `/og-image/projects/${project.id}.png?v=${ogImageVersion}`}
>
  <Container>
    <div class="animate">
      <BackToPrevious href="/projects">Back to projects</BackToPrevious>
    </div>
    <div class="animate mx-auto mt-10 mb-2 max-w-5xl space-y-1">
      <div class="flex items-center gap-1.5">
        <div class="font-base text-sm">
          <FormattedDate date={project.data.date} />
        </div>
        &bull;
        {
          project.body && (
            <div class="font-base text-sm">{readingTime(project.body)}</div>
          )
        }
      </div>
      <h1
        class="flex flex-wrap items-center gap-x-2 gap-y-1 text-3xl font-semibold text-black dark:text-white"
      >
        <span>{project.data.title}</span>
        <EntryBadges draft={project.data.draft} />
      </h1>
      {
        (project.data.demoURL || project.data.repoURL) && (
          <nav class="flex gap-1">
            {project.data.demoURL && (
              <Link href={project.data.demoURL} external>
                demo
              </Link>
            )}
            {project.data.demoURL && project.data.repoURL && <span>/</span>}
            {project.data.repoURL && (
              <Link href={project.data.repoURL} external>
                repo
              </Link>
            )}
          </nav>
        )
      }
    </div>

    {
      project.data.ogImage && (
        <section class="animate mx-auto mt-4 mb-8 max-w-5xl">
          <OgImage
            src={project.data.ogImage}
            sizes="(min-width: 1024px) 960px, calc(100vw - 1.5rem)"
            width={1200}
            height={675}
            fallbackWidth={1200}
            class="aspect-video w-full border border-black/10 object-cover dark:border-white/15"
          />
        </section>
      )
    }

    <div class="relative">
      {
        headings.length > 0 && (
          <aside class="mx-auto mb-0 max-w-5xl sm:mb-8 2xl:fixed 2xl:top-28 2xl:left-[calc(50%+34rem)] 2xl:mb-0 2xl:w-56 2xl:max-w-none">
            <TableOfContents headings={headings} />
          </aside>
        )
      }
      <article class="animate mx-auto max-w-5xl min-w-0">
        <Content />
      </article>
    </div>
  </Container>
</Layout>
