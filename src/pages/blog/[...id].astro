---
import { type CollectionEntry, getCollection, render } from "astro:content";
import BackToPrevious from "@components/BackToPrevious.astro";
import Container from "@components/Container.astro";
import FormattedDate from "@components/FormattedDate.astro";
import Giscus from "@components/Giscus.astro";
import PostNavigation from "@components/PostNavigation.astro";
import TableOfContents from "@components/TableOfContents.astro";
import { SITE } from "@consts";
import { sortByDateDesc } from "@lib/content-sort";
import Layout from "@layouts/Layout.astro";

export async function getStaticPaths() {
  const showDrafts = import.meta.env.DEV;
  const posts = sortByDateDesc(
    (await getCollection("blog")).filter(
      (post) => showDrafts || !post.data.draft,
    ),
  );
  return posts.map((post) => ({
    params: { id: post.id },
    props: post,
  }));
}
type Props = CollectionEntry<"blog">;

const showDrafts = import.meta.env.DEV;
const posts = sortByDateDesc(
  (await getCollection("blog")).filter(
    (post) => showDrafts || !post.data.draft,
  ),
);

function getNextPost() {
  const postIndex = posts.findIndex((post) => post.id === Astro.params.id);
  return postIndex >= 0 ? posts[postIndex + 1] : undefined;
}

function getPrevPost() {
  const postIndex = posts.findIndex((post) => post.id === Astro.params.id);
  return postIndex >= 0 ? posts[postIndex - 1] : undefined;
}

const nextPost = getNextPost();
const prevPost = getPrevPost();

const post = Astro.props;
const { Content, headings } = await render(post);
const ogImageVersion = "20260613-title-wrap";
const titleBackgroundImage =
  post.data.date.getDate() % 2 === 0 ? "/DSC_0098.webp" : "/DSC_0105.webp";
---

<Layout
  title={post.data.title}
  description={post.data.description ?? SITE.DESCRIPTION}
  image={post.data.ogImage ??
    `/og-image/blog/${post.id}.png?v=${ogImageVersion}`}
>
  <Container>
    <section
      class="post-title-hero animate mx-auto my-10 max-w-5xl overflow-hidden border border-black/10 dark:border-white/15"
      style={`--title-background-image: url("${titleBackgroundImage}")`}
    >
      <div class="relative z-10 space-y-5 px-6 py-10 sm:px-10 sm:py-14">
        <div class="flex items-center gap-1.5">
          <div class="font-base text-sm text-white/80">
            <FormattedDate date={post.data.date} />
          </div>
        </div>
        <h1 class="max-w-3xl text-3xl font-semibold text-white sm:text-4xl">
          {post.data.title}
          {
            post.data.draft && (
              <span class="ml-2 align-middle text-sm font-semibold text-red-200">
                (draft)
              </span>
            )
          }
        </h1>
        {
          post.data.tags && post.data.tags?.length > 0 ? (
            <div class="flex flex-wrap gap-2 pt-1">
              {post.data.tags.map((tag) => (
                <a
                  href={`/tags/${tag}`}
                  class="border border-white/25 bg-black/25 px-2 py-1 text-sm text-white/85 hover:bg-white/15 hover:text-white focus-visible:bg-white/15 focus-visible:text-white"
                >
                  {tag}
                </a>
              ))}
            </div>
          ) : null
        }
      </div>
    </section>
    <style>
      .post-title-hero {
        position: relative;
        background: #0b0f14;
        isolation: isolate;
      }

      .post-title-hero::before {
        position: absolute;
        inset: 0;
        z-index: -1;
        background: var(--title-background-image) center / cover;
        content: "";
      }

      .post-title-hero::after {
        position: absolute;
        inset: 0;
        z-index: -1;
        background: rgb(0 0 0 / 0.38);
        content: "";
      }
    </style>
    <div class="relative">
      {
        headings.length > 0 && (
          <aside class="mx-auto mb-8 max-w-5xl 2xl:absolute 2xl:top-0 2xl:left-[calc(100%+2rem)] 2xl:mb-0 2xl:w-56 2xl:max-w-none">
            <TableOfContents headings={headings} />
          </aside>
        )
      }
      <article class="animate mx-auto max-w-5xl min-w-0">
        <Content />
        <div class="mt-24">
          <PostNavigation prevPost={prevPost} nextPost={nextPost} />
        </div>
        <div class="mt-24">
          <Giscus />
        </div>
      </article>
    </div>
  </Container>
</Layout>
