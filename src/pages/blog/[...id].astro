---
import { type CollectionEntry, getCollection, render } from "astro:content";
import Container from "@components/Container.astro";
import EntryBadges from "@components/EntryBadges.astro";
import ShareButtons from "@components/ShareButtons.astro";
import FormattedDate from "@components/FormattedDate.astro";
import Giscus from "@components/Giscus.astro";
import OgImage from "@components/OgImage.astro";
import PostNavigation from "@components/PostNavigation.astro";
import TableOfContents from "@components/TableOfContents.astro";
import { SITE } from "@consts";
import { isVisibleEntry, sortByPinnedThenDateDesc } from "@lib/content-sort";
import Layout from "@layouts/Layout.astro";

export async function getStaticPaths() {
  const posts = sortByPinnedThenDateDesc(
    (await getCollection("blog")).filter(isVisibleEntry),
  );
  return posts.map((post) => ({
    params: { id: post.id },
    props: post,
  }));
}
type Props = CollectionEntry<"blog">;

const posts = sortByPinnedThenDateDesc(
  (await getCollection("blog")).filter(isVisibleEntry),
);

function getNextPost() {
  const postIndex = posts.findIndex((post) => post.id === Astro.params.id);
  return postIndex >= 0 ? posts[postIndex + 1] : undefined;
}

function getPrevPost() {
  const postIndex = posts.findIndex((post) => post.id === Astro.params.id);
  return postIndex >= 0 ? posts[postIndex - 1] : undefined;
}

const nextPost = getNextPost();
const prevPost = getPrevPost();

const post = Astro.props;
const { Content, headings } = await render(post);
const ogImageVersion = "20260614-og-background";
---

<Layout
  title={post.data.title}
  description={post.data.description ?? SITE.DESCRIPTION}
  image={post.data.ogImage ??
    `/og-image/blog/${post.id}.png?v=${ogImageVersion}`}
>
  <Container>
    <section class="animate mx-auto mt-0 mb-3 max-w-5xl px-3 sm:px-10">
      <div class="space-y-2">
        <h1
          class="flex flex-wrap items-center gap-x-2 gap-y-1 text-xl font-semibold text-black sm:text-3xl dark:text-white"
        >
          <span>{post.data.title}</span>
          <EntryBadges draft={post.data.draft} pinned={post.data.pinned} />
        </h1>
        <div class="font-base text-sm text-black/50 dark:text-white/50">
          <FormattedDate date={post.data.date} />
        </div>
      </div>
    </section>
    {
      post.data.ogImage && (
        <section class="animate mx-auto mt-4 mb-8 max-w-5xl px-3 sm:px-10">
          <OgImage
            src={post.data.ogImage}
            sizes="(min-width: 1024px) 960px, calc(100vw - 1.5rem)"
            width={1200}
            height={675}
            fallbackWidth={1200}
            class="aspect-video w-full border border-black/10 object-cover dark:border-white/15"
          />
        </section>
      )
    }
    <div class="relative">
      {
        headings.length > 0 && (
          <aside class="mx-auto mb-4 max-w-5xl px-3 sm:mb-8 sm:px-10 2xl:fixed 2xl:top-28 2xl:left-[calc(50%+34rem)] 2xl:mb-0 2xl:w-56 2xl:max-w-none 2xl:px-0">
            <TableOfContents headings={headings} />
          </aside>
        )
      }
      <article class="animate mx-0 max-w-none min-w-0 sm:mx-auto sm:max-w-5xl">
        <Content />
        <div class="mt-12 flex flex-col gap-8">
          {
            post.data.tags && post.data.tags?.length > 0 ? (
              <div class="flex flex-wrap gap-2">
                {post.data.tags.map((tag) => (
                  <a
                    href={`/tags/${tag}`}
                    class="border border-black/15 px-2 py-1 text-sm text-black/70 no-underline hover:bg-black/5 hover:text-black focus-visible:bg-black/5 focus-visible:text-black dark:border-white/20 dark:text-white/70 dark:hover:bg-white/5 dark:hover:text-white dark:focus-visible:bg-white/5 dark:focus-visible:text-white"
                  >
                    {tag}
                  </a>
                ))}
              </div>
            ) : null
          }
          <ShareButtons title={post.data.title} url={Astro.url.href} />
        </div>
        <div class="mt-24">
          <PostNavigation prevPost={prevPost} nextPost={nextPost} />
        </div>
        <div class="mt-24">
          <Giscus />
        </div>
      </article>
    </div>
  </Container>
</Layout>
