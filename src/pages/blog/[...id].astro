---
import { type CollectionEntry, getCollection, render } from "astro:content";
import BackToPrevious from "@components/BackToPrevious.astro";
import Container from "@components/Container.astro";
import FormattedDate from "@components/FormattedDate.astro";
import Giscus from "@components/Giscus.astro";
import PostNavigation from "@components/PostNavigation.astro";
import TableOfContents from "@components/TableOfContents.astro";
import Layout from "@layouts/Layout.astro";

export async function getStaticPaths() {
	const showDrafts = import.meta.env.DEV;
	const posts = (await getCollection("blog"))
		.filter((post) => showDrafts || !post.data.draft)
		.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
	return posts.map((post) => ({
		params: { id: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<"blog">;

const showDrafts = import.meta.env.DEV;
const posts = (await getCollection("blog"))
	.filter((post) => showDrafts || !post.data.draft)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function getNextPost() {
	const postIndex = posts.findIndex((post) => post.id === Astro.params.id);
	return postIndex >= 0 ? posts[postIndex + 1] : undefined;
}

function getPrevPost() {
	const postIndex = posts.findIndex((post) => post.id === Astro.params.id);
	return postIndex >= 0 ? posts[postIndex - 1] : undefined;
}

const nextPost = getNextPost();
const prevPost = getPrevPost();

const post = Astro.props;
const { Content, headings } = await render(post);
---

<Layout
  title={post.data.title}
  description={post.data.description}
  image={post.data.ogImage ?? `/og-image/blog/${post.id}.png`}
>
  <Container>
    <div class="mx-auto my-10 max-w-5xl space-y-4">
      <div class="animate flex items-center gap-1.5">
        <div class="font-base text-sm">
          <FormattedDate date={post.data.date} />
        </div>
      </div>
      <h1 class="animate text-3xl font-semibold text-black dark:text-white">
        {post.data.title}
        {post.data.draft && (
          <span class="ml-2 align-middle text-sm font-semibold text-red-600 dark:text-red-400">
            (draft)
          </span>
        )}
      </h1>
      {
        post.data.tags && post.data.tags?.length > 0 ? (
          <div class="animate flex gap-2 pt-1">
            {post.data.tags.map((tag) => (
              <a
                href={`/tags/${tag}`}
                class="border border-black/15 px-2 py-1 text-sm hover:bg-black/5 hover:text-black focus-visible:bg-black/5 focus-visible:text-black dark:border-white/20 dark:hover:bg-white/5 dark:hover:text-white dark:focus-visible:bg-white/5 dark:focus-visible:text-white"
              >
                {tag}
              </a>
            ))}
          </div>
        ) : null
      }
    </div>
    <div class="relative">
      {headings.length > 0 && (
        <aside class="mx-auto mb-8 max-w-5xl 2xl:fixed 2xl:left-[calc(50%+34rem)] 2xl:top-28 2xl:bottom-40 2xl:mb-0 2xl:w-56 2xl:max-w-none">
          <TableOfContents headings={headings} />
        </aside>
      )}
      <article class="animate mx-auto min-w-0 max-w-5xl">
        <Content />
        <div class="mt-24">
          <PostNavigation prevPost={prevPost} nextPost={nextPost} />
        </div>
        <div class="mt-24">
          <Giscus />
        </div>
      </article>
    </div>
  </Container>
</Layout>
