---
import { getCollection } from "astro:content";
import CommitHeatmap from "@components/CommitHeatmap.astro";
import Container from "@components/Container.astro";
import { BLOG } from "@consts";
import { sortByDateDesc } from "@lib/content-sort";
import Layout from "@layouts/Layout.astro";
import { dateKey, formatDateJP, getTextStats } from "@lib/post-metrics";

const showDrafts = import.meta.env.DEV;
const now = new Date();
const rangeStart = new Date(now.getFullYear(), now.getMonth() - 5, 1);

const entries = sortByDateDesc(
  (await getCollection("blog"))
    .filter((post) => showDrafts || !post.data.draft)
    .filter((post) => post.data.date >= rangeStart && post.data.date <= now),
).map((entry) => ({
  entry,
  charCount: getTextStats(entry.body ?? "").charCount,
}));

const months = Array.from({ length: 6 }, (_, index) => {
  const date = new Date(
    rangeStart.getFullYear(),
    rangeStart.getMonth() + index,
    1,
  );
  const key = dateKey(date).slice(0, 7);
  const label = new Intl.DateTimeFormat("en-US", { month: "short" }).format(
    date,
  );
  return { key, label };
});

const count = (map: Map<string, number>, key: string, value = 1) =>
  map.set(key, (map.get(key) ?? 0) + value);
const monthKeys = new Set(months.map((month) => month.key));
const dayCounts = new Map<string, number>();
const monthTagCounts = new Map<string, Map<string, number>>();
const tagTotals = new Map<string, number>();
const otherTag = "その他";
let periodCharTotal = 0;

for (const { entry, charCount } of entries) {
  periodCharTotal += charCount;
  count(dayCounts, dateKey(entry.data.date));
  const monthKey = dateKey(entry.data.date).slice(0, 7);
  if (!monthKeys.has(monthKey)) continue;

  const monthMap = monthTagCounts.get(monthKey) ?? new Map<string, number>();
  monthTagCounts.set(monthKey, monthMap);
  for (const tag of entry.data.tags?.length ? entry.data.tags : ["未分類"]) {
    count(tagTotals, tag);
    count(monthMap, tag);
  }
}

const topTags = Array.from(tagTotals.entries())
  .sort((a, b) => b[1] - a[1])
  .slice(0, 4)
  .map(([tag]) => tag);

const monthlyTagSeries = months.map((month) => {
  const row: Record<string, number | string> = Object.fromEntries(
    topTags.map((tag) => [tag, 0]),
  );
  row.monthLabel = month.label;
  const monthMap = monthTagCounts.get(month.key);
  let otherCount = 0;

  for (const [tag, count] of monthMap ?? []) {
    if (topTags.includes(tag)) row[tag] = count;
    else otherCount += count;
  }

  row[otherTag] = otherCount;
  return row;
});
const hasOther = monthlyTagSeries.some((row) => Number(row[otherTag] ?? 0) > 0);
const stackedTags = hasOther ? [...topTags, otherTag] : topTags;
const tagColors = [
  "hsl(217, 91%, 60%)",
  "hsl(217, 91%, 75%)",
  "hsl(199, 89%, 60%)",
  "hsl(199, 89%, 70%)",
  "hsl(215, 16%, 65%)",
];
const tagTotalsByMonth = monthlyTagSeries.map((row) =>
  stackedTags.reduce((sum, tag) => sum + Number(row[tag] ?? 0), 0),
);
const maxTagTotal = Math.max(1, ...tagTotalsByMonth);
const tagColor = (tag: string, index: number) =>
  tagColors[tag === otherTag ? 4 : index % tagColors.length];
const monthlyBars = monthlyTagSeries.map((row, index) => {
  const total = tagTotalsByMonth[index] ?? 0;
  let offset = 0;
  const segments = stackedTags
    .map((tag, tagIndex) => {
      const value = Number(row[tag] ?? 0);
      if (value <= 0 || total <= 0) return "";
      const start = offset;
      offset += (value / total) * 100;
      return `${tagColor(tag, tagIndex)} ${start}% ${offset}%`;
    })
    .filter(Boolean);

  return {
    label: row.monthLabel,
    title: `${row.monthLabel}: ${total.toLocaleString("ja-JP")}件`,
    style: `height:${(total / maxTagTotal) * 100}%;background:linear-gradient(to top,${segments.join(",")})`,
  };
});

const graphEnd = new Date(now.getFullYear(), now.getMonth(), now.getDate());
const graphStart = new Date(rangeStart);
graphStart.setDate(graphStart.getDate() - graphStart.getDay());

const days: Array<{ date: Date; count: number }> = [];
for (
  let cursor = new Date(graphStart);
  cursor <= graphEnd;
  cursor.setDate(cursor.getDate() + 1)
) {
  const date = new Date(cursor);
  days.push({ date, count: dayCounts.get(dateKey(date)) ?? 0 });
}

const weeks = Array.from({ length: Math.ceil(days.length / 7) }, (_, index) =>
  days.slice(index * 7, index * 7 + 7),
);

const monthLabels = weeks.map((week) => {
  const firstDay = week[0]?.date;
  return firstDay && firstDay.getDate() <= 7
    ? new Intl.DateTimeFormat("ja-JP", { month: "numeric" }).format(firstDay)
    : "";
});

const maxDaily = Math.max(1, ...dayCounts.values());
const heatmapClasses = [
  "bg-black/5 dark:bg-white/5",
  "bg-sky-100 dark:bg-sky-500/20",
  "bg-sky-200 dark:bg-sky-500/35",
  "bg-sky-300 dark:bg-sky-500/55",
  "bg-sky-400 dark:bg-sky-500/80",
];
const heatmapLevel = (count: number) => {
  if (count === 0) return 0;
  const ratio = count / maxDaily;
  if (ratio >= 0.8) return 4;
  if (ratio >= 0.6) return 3;
  if (ratio >= 0.3) return 2;
  return 1;
};
const heatmapWeeks = weeks.map((week) =>
  week.map((day) => {
    return {
      date: formatDateJP(day.date),
      count: day.count,
      className: heatmapClasses[heatmapLevel(day.count)],
    };
  }),
);
const topPosts = entries
  .map(({ entry, charCount }) => ({
    id: entry.id,
    title: entry.data.title,
    date: formatDateJP(entry.data.date),
    charCount,
  }))
  .sort((a, b) => b.charCount - a.charCount)
  .slice(0, 8);
---

<Layout title="Stats" description={BLOG.DESCRIPTION}>
  <Container>
    <div class="min-w-0 space-y-6">
      <section class="space-y-1 text-center sm:text-left">
        <h1 class="text-2xl font-semibold text-black dark:text-white">統計</h1>
      </section>

      <section
        class="border border-black/10 bg-white/80 p-4 dark:border-white/10 dark:bg-neutral-900/70"
      >
        <div
          class="flex flex-col gap-2 text-center sm:flex-row sm:items-start sm:justify-between sm:text-left"
        >
          <div>
            <div class="text-sm font-semibold text-black/70 dark:text-white/70">
              執筆文字数
            </div>
            <div class="mt-1 text-xs text-black/40 dark:text-white/40">
              直近6か月の集計結果
            </div>
          </div>
          <div
            class="text-2xl font-semibold text-black sm:text-right dark:text-white"
          >
            {periodCharTotal.toLocaleString("ja-JP")} 字
          </div>
        </div>

        <div class="mt-4 overflow-x-auto overflow-y-visible">
          <CommitHeatmap weeks={heatmapWeeks} monthLabels={monthLabels} />
        </div>
      </section>

      <section
        class="border border-black/10 bg-white/80 p-4 dark:border-white/10 dark:bg-neutral-900/70"
      >
        <div
          class="flex h-[280px] items-end gap-3 border-b border-black/10 dark:border-white/10"
        >
          {
            monthlyBars.map((bar) => (
              <div class="flex h-full flex-1 flex-col justify-end gap-2">
                <div
                  class="w-full overflow-hidden"
                  title={bar.title}
                  style={bar.style}
                />
                <span class="text-center text-xs text-black/50 dark:text-white/50">
                  {bar.label}
                </span>
              </div>
            ))
          }
        </div>
        <div class="mt-3 text-xs text-black/60 dark:text-white/60">
          {stackedTags.join(" / ")}
        </div>
      </section>

      <section
        class="border border-black/10 bg-white/80 p-4 dark:border-white/10 dark:bg-neutral-900/70"
      >
        <div class="text-center sm:text-left">
          <div class="text-sm font-semibold text-black/70 dark:text-white/70">
            投稿ごとの執筆文字数
          </div>
        </div>

        <div class="mt-4 divide-y divide-black/5 text-sm dark:divide-white/10">
          {
            topPosts.map((post) => (
              <a
                href={`/blog/${post.id}`}
                class="flex flex-col gap-2 py-3 sm:flex-row sm:items-center sm:justify-between"
              >
                <div class="min-w-0">
                  <div class="truncate font-semibold text-black dark:text-white">
                    {post.title}
                  </div>
                  <div class="mt-1 text-xs text-black/40 dark:text-white/40">
                    {post.date}に公開
                  </div>
                </div>
                <div class="text-left text-sm font-semibold text-black sm:text-right dark:text-white">
                  {post.charCount.toLocaleString("ja-JP")} 字
                </div>
              </a>
            ))
          }
        </div>
      </section>
    </div>
  </Container>
</Layout>
