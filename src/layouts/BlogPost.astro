---
import type { MarkdownHeading } from "astro";
import type { CollectionEntry } from "astro:content";

import Masthead from "@/components/blog/Masthead.astro";
import TOC from "@/components/blog/TOC.astro";
import WebMentions from "@/components/blog/webmentions/index.astro";
import { siteConfig } from "@/site.config";

import BaseLayout from "./Base.astro";

interface Props {
	post: CollectionEntry<"post">;
	headings: MarkdownHeading[];
	readingTime: string;
}

const { post, headings, readingTime } = Astro.props;
const { ogImage, title, description, updatedDate, publishDate, coverImage } = post.data;
const safePublishDate = publishDate instanceof Date ? publishDate : new Date(publishDate);
const safeUpdatedDate = updatedDate
	? updatedDate instanceof Date
		? updatedDate
		: new Date(updatedDate)
	: undefined;
const socialImage = ogImage ?? `/og-image/${post.id}.png`;
const coverSrc =
	typeof coverImage?.src === "string" ? coverImage.src : coverImage?.src?.src;
const articleDate = (safeUpdatedDate ?? safePublishDate).toISOString();
const layoutProps = {
	meta: {
		articleDate,
		description: description ?? siteConfig.description,
		ogImage: socialImage,
		preloadImage: coverSrc,
		title,
	},
	...(coverSrc ? { headerImage: coverSrc, headerOverlay: true } : {}),
};
---

<BaseLayout {...layoutProps}>
	<article class="grow break-words" data-pagefind-body>
		<div id="blog-hero" class="mb-5"><Masthead content={post} readingTime={readingTime} /></div>
		<hr class="mb-10 border-0 border-t border-black/10 dark:border-white/10" />
		<div class="flex flex-col gap-10 lg:flex-row lg:items-start lg:justify-between">
			{!!headings.length && <TOC headings={headings} />}
			<div
				class="prose prose-sm prose-headings:font-semibold prose-headings:text-accent-2 sm:prose-th:before:content-none tracking-[0.02em] leading-[1.85] text-[0.8rem] sm:text-[1.1rem] font-hiragino max-w-[68ch] lg:max-w-[72ch] mx-auto"
			>
				<slot />
				<WebMentions />
			</div>
		</div>
	</article>
	<button
		class="hover:border-link fixed end-4 bottom-8 z-90 flex h-10 w-10 translate-y-28 cursor-pointer items-center justify-center rounded-full border-2 border-transparent bg-zinc-200 text-3xl opacity-0 transition-all transition-discrete duration-300 data-[show=true]:translate-y-0 data-[show=true]:opacity-100 sm:end-8 sm:h-12 sm:w-12 dark:bg-zinc-700"
		data-show="false"
		id="to-top-btn"
	>
		<span class="sr-only">Back to top</span>
		<svg
			aria-hidden="true"
			class="h-6 w-6"
			fill="none"
			focusable="false"
			stroke="currentColor"
			stroke-width="2"
			viewBox="0 0 24 24"
			xmlns="http://www.w3.org/2000/svg"
		>
			<path d="M4.5 15.75l7.5-7.5 7.5 7.5" stroke-linecap="round" stroke-linejoin="round"></path>
		</svg>
	</button>
</BaseLayout>

<script>
	const scrollBtn = document.getElementById("to-top-btn") as HTMLButtonElement;
	const targetHeader = document.getElementById("blog-hero") as HTMLDivElement;

	function callback(entries: IntersectionObserverEntry[]) {
		entries.forEach((entry) => {
			// only show the scroll to top button when the heading is out of view
			scrollBtn.dataset.show = (!entry.isIntersecting).toString();
		});
	}

	scrollBtn.addEventListener("click", () => {
		document.documentElement.scrollTo({ behavior: "smooth", top: 0 });
	});

	const observer = new IntersectionObserver(callback);
	observer.observe(targetHeader);
</script>
