---
import BaseHead from "@/components/BaseHead.astro";
import Footer from "@/components/layout/Footer.astro";
import Header from "@/components/layout/Header.astro";
import SkipLink from "@/components/SkipLink.astro";
import { siteConfig } from "@/site.config";
import type { SiteMeta } from "@/types";

interface Props {
	meta: SiteMeta;
	showHeader?: boolean;
	headerImage?: string | undefined;
	headerOverlay?: boolean | undefined;
}

const {
	meta: { articleDate, description = siteConfig.description, ogImage, preloadImage, title },
	showHeader = true,
	headerImage,
	headerOverlay = false,
} = Astro.props;

const headerProps = {
	...(headerImage ? { imageUrl: headerImage } : {}),
	...(headerOverlay ? { overlay: true } : {}),
};
---

<html class="scroll-smooth" lang={siteConfig.lang}>
	<head>
		<BaseHead
			articleDate={articleDate}
			description={description}
			ogImage={ogImage}
			preloadImage={preloadImage}
			title={title}
		/>
	</head>
	<body
		class="bg-global-bg text-global-text mx-auto flex min-h-screen max-w-4xl flex-col px-4 pt-8 font-mono text-sm font-normal antialiased sm:px-8"
	>
		<SkipLink />
		{showHeader && <Header {...headerProps} />}
		<main id="main">
			<slot />
		</main>
		<Footer />
		<script is:inline>
			const hasTwitterEmbeds = () =>
				!!document.querySelector(
					"blockquote.twitter-tweet, .twitter-timeline, [data-twitter-embed]",
				);

			if (hasTwitterEmbeds()) {
				if (window.twttr?.widgets) {
					window.twttr.widgets.load();
				} else if (!document.querySelector("script[data-twitter-wjs]")) {
					const script = document.createElement("script");
					script.src = "https://platform.twitter.com/widgets.js";
					script.async = true;
					script.charset = "utf-8";
					script.dataset.twitterWjs = "true";
					script.onload = () => window.twttr?.widgets?.load();
					document.body.appendChild(script);
				}
			}
		</script>
		<script is:inline>
			const prefetched = new Set();
			const MAX_PREFETCH = 8;

			const prefetchPage = (url) => {
				if (!url || prefetched.size >= MAX_PREFETCH) return;
				let resolved;
				try {
					resolved = new URL(url, window.location.href);
				} catch {
					return;
				}
				if (resolved.origin !== window.location.origin) return;
				if (prefetched.has(resolved.href)) return;
				prefetched.add(resolved.href);
				fetch(resolved.href, { credentials: "same-origin", cache: "force-cache" }).catch(
					() => {},
				);
			};

			const schedulePrefetch = (url) => {
				if (!url) return;
				if ("requestIdleCallback" in window) {
					window.requestIdleCallback(() => prefetchPage(url), { timeout: 1200 });
				} else {
					setTimeout(() => prefetchPage(url), 150);
				}
			};

			const onHint = (event) => {
				const target = event.target;
				if (!(target instanceof HTMLElement)) return;
				const link = target.closest("a[data-prefetch]");
				if (!(link instanceof HTMLAnchorElement)) return;
				schedulePrefetch(link.href);
			};

			const warmStart = () => {
				const links = Array.from(document.querySelectorAll("a[data-prefetch]")).slice(0, 3);
				for (const link of links) {
					if (!(link instanceof HTMLAnchorElement)) continue;
					schedulePrefetch(link.href);
				}
			};

			document.addEventListener("pointerover", onHint, { passive: true, capture: true });
			document.addEventListener("touchstart", onHint, { passive: true, capture: true });
			document.addEventListener("focusin", onHint);
			if (document.readyState === "complete") {
				warmStart();
			} else {
				window.addEventListener("load", warmStart, { once: true });
			}
		</script>
	</body>
</html>
