---
import BaseHead from "@/components/BaseHead.astro";
import Footer from "@/components/layout/Footer.astro";
import Header from "@/components/layout/Header.astro";
import SkipLink from "@/components/SkipLink.astro";
import ThemeProvider from "@/components/ThemeProvider.astro";
import { siteConfig } from "@/site.config";
import type { SiteMeta } from "@/types";

interface Props {
	meta: SiteMeta;
}

const {
	meta: { articleDate, description = siteConfig.description, ogImage, preloadImage, title },
} = Astro.props;
---

<html class="scroll-smooth" lang={siteConfig.lang}>
	<head>
		<BaseHead
			articleDate={articleDate}
			description={description}
			ogImage={ogImage}
			preloadImage={preloadImage}
			title={title}
		/>
	</head>
	<body
		class="bg-global-bg text-global-text mx-auto flex min-h-screen max-w-4xl flex-col px-4 pt-8 font-mono text-sm font-normal antialiased sm:px-8"
	>
		<ThemeProvider />
		<SkipLink />
		<Header />
		<main id="main">
			<slot />
		</main>
		<Footer />
		<script is:inline>
			const hasTwitterEmbeds = () =>
				!!document.querySelector(
					"blockquote.twitter-tweet, .twitter-timeline, [data-twitter-embed]",
				);

			const loadTwitterWidgets = () => {
				if (!hasTwitterEmbeds()) return;
				if (window.twttr?.widgets) {
					window.twttr.widgets.load();
					return;
				}
				if (document.querySelector("script[data-twitter-wjs]")) return;
				const script = document.createElement("script");
				script.src = "https://platform.twitter.com/widgets.js";
				script.async = true;
				script.charset = "utf-8";
				script.dataset.twitterWjs = "true";
				script.onload = () => window.twttr?.widgets?.load();
				document.body.appendChild(script);
			};

			const initImageLightbox = () => {
				if (document.body.dataset.lightboxBound) return;
				document.body.dataset.lightboxBound = "true";

				const overlay = document.createElement("div");
				overlay.className = "image-lightbox";
				overlay.dataset.open = "false";
				const overlayImg = document.createElement("img");
				overlayImg.alt = "";
				overlay.appendChild(overlayImg);
				document.body.appendChild(overlay);

				const close = () => {
					overlay.dataset.open = "false";
					document.body.classList.remove("image-lightbox-open");
				};

				overlay.addEventListener("click", (event) => {
					event.preventDefault();
					close();
				});

				document.addEventListener("keydown", (event) => {
					if (event.key === "Escape" && overlay.dataset.open === "true") close();
				});

				document.addEventListener(
					"click",
					(event) => {
						const target = event.target;
						if (!(target instanceof HTMLElement)) return;
						const img = target.closest("img");
						if (!img) return;
						if (!img.closest("article")) return;

						event.preventDefault();
						overlayImg.src = img.currentSrc || img.src;
						overlayImg.alt = img.getAttribute("alt") ?? "";
						overlay.dataset.open = "true";
						document.body.classList.add("image-lightbox-open");
					},
					{ capture: true },
				);
			};

			const prefetchState = {
				pages: new Set(),
				images: new Set(),
				origins: new Set(),
			};

			const canPrefetch = () => {
				const connection = navigator.connection;
				if (connection?.saveData) return false;
				if (connection?.effectiveType && /2g/.test(connection.effectiveType)) return false;
				if (window.matchMedia?.("(prefers-reduced-data: reduce)")?.matches) return false;
				return true;
			};

			const ensurePreconnect = (origin) => {
				if (!origin || origin === window.location.origin) return;
				if (prefetchState.origins.has(origin)) return;
				prefetchState.origins.add(origin);

				const preconnect = document.createElement("link");
				preconnect.rel = "preconnect";
				preconnect.href = origin;
				preconnect.crossOrigin = "anonymous";
				document.head.appendChild(preconnect);

				const dns = document.createElement("link");
				dns.rel = "dns-prefetch";
				dns.href = origin;
				document.head.appendChild(dns);
			};

			const prefetchImage = (src) => {
				if (!src || src.startsWith("data:")) return;
				const url = new URL(src, window.location.href);
				if (prefetchState.images.has(url.href)) return;
				prefetchState.images.add(url.href);
				ensurePreconnect(url.origin);
				const link = document.createElement("link");
				link.rel = "prefetch";
				link.as = "image";
				link.href = url.href;
				document.head.appendChild(link);
			};

			const prefetchPage = async (url, { images = false } = {}) => {
				if (!url || prefetchState.pages.has(url)) return;
				prefetchState.pages.add(url);
				try {
					const res = await fetch(url, { credentials: "same-origin", cache: "force-cache" });
					if (!res.ok) return;
					if (!images) return;
					const html = await res.text();
					const doc = new DOMParser().parseFromString(html, "text/html");
					const imgNodes = Array.from(doc.querySelectorAll("article img"));
					const srcs = imgNodes
						.map((img) => img.getAttribute("src") || "")
						.filter(Boolean);
					const unique = [...new Set(srcs)].slice(0, 12);
					unique.forEach((src) => prefetchImage(new URL(src, url).href));
				} catch {
					// ignore
				}
			};

			const bindPrefetchListeners = () => {
				if (document.body.dataset.prefetchBound) return;
				document.body.dataset.prefetchBound = "true";

				const handler = (event) => {
					if (!canPrefetch()) return;
					const target = event.target;
					if (!(target instanceof HTMLElement)) return;
					const link = target.closest("a[data-prefetch]");
					if (!(link instanceof HTMLAnchorElement)) return;
					const mode = link.dataset.prefetch ?? "";
					prefetchPage(link.href, { images: mode === "post" });
				};

				document.addEventListener("pointerover", handler, { passive: true, capture: true });
				document.addEventListener("touchstart", handler, { passive: true, capture: true });
				document.addEventListener("focusin", handler);
			};

			const prefetchInitialPosts = () => {
				if (!canPrefetch()) return;
				const links = Array.from(document.querySelectorAll("a[data-prefetch='post']")).slice(0, 8);
				const run = () => links.forEach((link) => prefetchPage(link.href, { images: true }));
				if ("requestIdleCallback" in window) {
					window.requestIdleCallback(run, { timeout: 2000 });
				} else {
					setTimeout(run, 1000);
				}
			};

			const prefetchVisiblePosts = () => {
				if (!canPrefetch()) return;
				if (!("IntersectionObserver" in window)) return;
				const links = Array.from(document.querySelectorAll("a[data-prefetch='post']"));
				if (links.length === 0) return;

				const observer = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (!entry.isIntersecting) return;
							const link = entry.target;
							if (!(link instanceof HTMLAnchorElement)) return;
							observer.unobserve(link);
							prefetchPage(link.href, { images: true });
						});
					},
					{ rootMargin: "200px 0px" },
				);

				links.forEach((link) => observer.observe(link));
			};

			const onPageLoad = () => {
				initImageLightbox();
				bindPrefetchListeners();
				prefetchInitialPosts();
				prefetchVisiblePosts();
				if ("requestIdleCallback" in window) {
					window.requestIdleCallback(loadTwitterWidgets, { timeout: 2000 });
				} else {
					setTimeout(loadTwitterWidgets, 1200);
				}
			};

			window.addEventListener("load", onPageLoad);
			document.addEventListener("astro:page-load", onPageLoad);
		</script>
		<script is:inline type="speculationrules">
			{
				"prefetch": [
					{
						"where": {
							"selector_matches": "a[data-prefetch='page']"
						},
						"eagerness": "conservative"
					}
				],
				"prerender": [
					{
						"where": {
							"selector_matches": "a[data-prerender='true']"
						},
						"eagerness": "moderate"
					}
				]
			}
		</script>
	</body>
</html>
