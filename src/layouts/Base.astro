---
import BaseHead from "@/components/BaseHead.astro";
import Footer from "@/components/layout/Footer.astro";
import Header from "@/components/layout/Header.astro";
import SkipLink from "@/components/SkipLink.astro";
import { siteConfig } from "@/site.config";
import type { SiteMeta } from "@/types";

interface Props {
	meta: SiteMeta;
	showHeader?: boolean;
	headerImage?: string | undefined;
	headerOverlay?: boolean | undefined;
}

const {
	meta: { articleDate, description = siteConfig.description, ogImage, preloadImage, title },
	showHeader = true,
	headerImage,
	headerOverlay = false,
} = Astro.props;

const headerProps = {
	...(headerImage ? { imageUrl: headerImage } : {}),
	...(headerOverlay ? { overlay: true } : {}),
};
---

<html class="scroll-smooth" lang={siteConfig.lang}>
	<head>
		<BaseHead
			articleDate={articleDate}
			description={description}
			ogImage={ogImage}
			preloadImage={preloadImage}
			title={title}
		/>
	</head>
	<body
		class="bg-global-bg text-global-text mx-auto flex min-h-screen max-w-4xl flex-col px-4 pt-8 font-mono text-sm font-normal antialiased sm:px-8"
	>
		<SkipLink />
		{showHeader && <Header {...headerProps} />}
		<main id="main">
			<slot />
		</main>
		<Footer />
		<script is:inline>
			const hasTwitterEmbeds = () =>
				!!document.querySelector(
					"blockquote.twitter-tweet, .twitter-timeline, [data-twitter-embed]",
				);

			if (hasTwitterEmbeds()) {
				if (window.twttr?.widgets) {
					window.twttr.widgets.load();
				} else if (!document.querySelector("script[data-twitter-wjs]")) {
					const script = document.createElement("script");
					script.src = "https://platform.twitter.com/widgets.js";
					script.async = true;
					script.charset = "utf-8";
					script.dataset.twitterWjs = "true";
					script.onload = () => window.twttr?.widgets?.load();
					document.body.appendChild(script);
				}
			}
		</script>
	</body>
</html>
