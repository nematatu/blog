---
type Props = {
  draft?: boolean;
  pinned?: boolean;
};

const { draft, pinned } = Astro.props as Props;
---

{
  pinned && (
    <span class="inline-flex items-center rounded border border-blue-500/25 bg-blue-500/10 px-1.5 py-0.5 text-[10px] leading-none font-semibold text-blue-700 dark:text-blue-300">
      固定
    </span>
  )
}
{
  draft && (
    <span class="inline-flex items-center rounded border border-red-500/25 bg-red-500/10 px-1.5 py-0.5 text-[10px] leading-none font-semibold text-red-700 dark:text-red-300">
      draft
    </span>
  )
}
