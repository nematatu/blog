---
type Props = {
  draft?: boolean;
};

const { draft } = Astro.props as Props;
---

{
  draft && (
    <span class="inline-flex items-center rounded border border-red-500/25 bg-red-500/10 px-1.5 py-0.5 text-[10px] leading-none font-semibold text-red-700 dark:text-red-300">
      draft
    </span>
  )
}
