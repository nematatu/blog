---
import type { CollectionEntry } from "astro:content";
import { formatDateJP } from "@lib/post-metrics";
import { cn } from "@lib/utils";

type Props = {
  entry: CollectionEntry<"blog">;
  class?: string;
};

const { entry, class: className } = Astro.props as Props;
const dateLabel = formatDateJP(entry.data.date);
const ogImage = entry.data.ogImage;
---

<a href={`/blog/${entry.id}`} class={cn("group block py-4", className)}>
  <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:gap-4">
    <div class="shrink-0 text-xs text-black/50 dark:text-white/45">
      {dateLabel}
    </div>
    <div class="flex min-w-0 flex-col gap-2 sm:flex-row sm:items-center">
      {
        ogImage && (
          <img
            src={ogImage}
            alt=""
            class="aspect-[1200/630] w-28 shrink-0 border border-black/10 object-cover sm:w-24 dark:border-white/15"
            loading="lazy"
            decoding="async"
            aria-hidden="true"
          />
        )
      }
      <h3
        class="min-w-0 text-base font-medium text-blue-700 underline underline-offset-4 group-hover:text-blue-900 dark:text-blue-300 dark:group-hover:text-blue-200"
      >
        {entry.data.title}
        {
          entry.data.draft && (
            <span class="ml-2 text-xs font-semibold text-red-600 dark:text-red-400">
              (draft)
            </span>
          )
        }
      </h3>
    </div>
  </div>
</a>
