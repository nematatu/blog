---
import type { CollectionEntry } from "astro:content";
import { formatDateJP } from "@lib/post-metrics";
import { cn } from "@lib/utils";

type Props = {
  entry: CollectionEntry<"blog">;
  class?: string;
};

const { entry, class: className } = Astro.props as Props;
const dateLabel = formatDateJP(entry.data.date);
const ogImage = entry.data.ogImage;
---

<a
  href={`/blog/${entry.id}`}
  class={cn(
    "group block py-6 px-4 -mx-4 rounded-xl border-b border-black/5 dark:border-white/5 last:border-0 hover:bg-black/5 dark:hover:bg-white/5 transition-colors duration-200",
    className,
  )}
>
  <div class="flex flex-col gap-4 sm:flex-row sm:gap-6">
    {
      ogImage && (
        <div class="aspect-[1200/630] w-full shrink-0 overflow-hidden rounded-lg border border-black/10 sm:w-48 dark:border-white/15">
          <img
            src={ogImage}
            alt=""
            class="h-full w-full object-cover"
            loading="lazy"
            decoding="async"
            aria-hidden="true"
          />
        </div>
      )
    }
    <div class="flex min-w-0 flex-1 flex-col justify-between">
      <div class="space-y-2">
        <h3
          class="text-lg leading-tight font-bold text-black transition-colors group-hover:text-blue-600 sm:text-xl dark:text-white dark:group-hover:text-blue-400"
        >
          {entry.data.title}
          {
            entry.data.draft && (
              <span class="ml-2 align-middle text-xs font-semibold text-red-600 dark:text-red-400">
                (draft)
              </span>
            )
          }
        </h3>
        {
          entry.data.description && (
            <p class="line-clamp-2 text-sm text-black/60 dark:text-white/60">
              {entry.data.description}
            </p>
          )
        }
      </div>

      <div
        class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2 text-xs text-black/50 dark:text-white/45"
      >
        <time datetime={entry.data.date.toISOString()}>
          {dateLabel}
        </time>
        {
          entry.data.tags && entry.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {entry.data.tags.map((tag) => (
                <span class="rounded bg-black/5 px-2 py-0.5 text-[10px] font-medium tracking-wider uppercase dark:bg-white/5">
                  #{tag}
                </span>
              ))}
            </div>
          )
        }
      </div>
    </div>
  </div>
</a>
