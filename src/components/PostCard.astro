---
import type { CollectionEntry } from "astro:content";
import EntryBadges from "@components/EntryBadges.astro";
import OgImage from "@components/OgImage.astro";
import PinnedIndicator from "@components/PinnedIndicator.astro";
import { formatDateJP } from "@lib/post-metrics";
import { cn } from "@lib/utils";

type Props = {
  entry: CollectionEntry<"blog">;
  class?: string;
};

const { entry, class: className } = Astro.props as Props;
const dateLabel = formatDateJP(entry.data.date);
const ogImage = entry.data.ogImage;
---

<a
  href={`/blog/${entry.id}`}
  class={cn(
    "group block py-6 px-4 -mx-4 rounded-xl border-b border-black/5 dark:border-white/5 last:border-0 hover:bg-black/5 dark:hover:bg-white/5 transition-colors duration-200",
    className,
  )}
>
  <div class="flex flex-col gap-4 sm:flex-row sm:gap-6">
    {
      ogImage && (
        <div class="aspect-video w-full shrink-0 overflow-hidden rounded-lg border border-black/10 sm:w-48 dark:border-white/15">
          <OgImage
            src={ogImage}
            sizes="(min-width: 640px) 12rem, calc(100vw - 2rem)"
            width={480}
            height={270}
            class="h-full w-full object-cover"
            loading="lazy"
          />
        </div>
      )
    }
    <div class="flex min-w-0 flex-1 flex-col justify-between">
      <div class="space-y-2">
        <h3
          class="flex flex-wrap items-center gap-x-2 gap-y-1 text-lg leading-tight font-bold text-black transition-colors group-hover:text-blue-700 sm:text-xl dark:text-white dark:group-hover:text-blue-400"
        >
          <span>{entry.data.title}</span>
          <EntryBadges draft={entry.data.draft} />
        </h3>
        {
          entry.data.description && (
            <p class="line-clamp-2 text-sm text-black/60 dark:text-white/60">
              {entry.data.description}
            </p>
          )
        }
      </div>

      <div
        class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2 text-xs text-black/50 dark:text-white/45"
      >
        {entry.data.pinned && <PinnedIndicator />}
        <time datetime={entry.data.date.toISOString()}>
          {dateLabel}
        </time>
        {
          entry.data.tags && entry.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {entry.data.tags.map((tag) => (
                <span class="rounded bg-black/5 px-2 py-0.5 text-[10px] font-medium tracking-wider dark:bg-white/5">
                  #{tag}
                </span>
              ))}
            </div>
          )
        }
      </div>
    </div>
  </div>
</a>
