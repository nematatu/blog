---
import type { HTMLAttributes } from "astro/types";
import { getFormattedDate } from "@/utils/date";

type Props = HTMLAttributes<"time"> & {
	date: Date | string | number;
	dateTimeOptions?: Intl.DateTimeFormatOptions;
	format?: "ymd";
};

const { date, dateTimeOptions, format, ...attrs } = Astro.props;
const safeDate = date instanceof Date ? date : new Date(date);

const postDate =
	format === "ymd"
		? `${safeDate.getFullYear()}-${safeDate.getMonth() + 1}-${safeDate.getDate()}`
		: getFormattedDate(safeDate, dateTimeOptions);
const ISO = safeDate.toISOString();
---

<time datetime={ISO} title={ISO} {...attrs}>{postDate}</time>
