---
import TableOfContentsHeading from "./TableOfContentsHeading.astro";

// https://kld.dev/building-table-of-contents/
const { headings = [] } = Astro.props as { headings?: Heading[] };
const toc = buildToc(headings);
const isLongToc = headings.length > 12;
const detailsAttrs = isLongToc ? {} : { open: true };

export interface Heading {
  depth: number;
  slug: string;
  text: string;
}

type TocHeading = Heading & { subheadings: TocHeading[] };

function buildToc(headings: Heading[] = []) {
  const toc: TocHeading[] = [];
  const parentHeadings = new Map<number, TocHeading>();
  headings.forEach((h) => {
    const heading: TocHeading = { ...h, subheadings: [] };
    parentHeadings.set(heading.depth, heading);
    if (heading.depth === 2) {
      toc.push(heading);
      return;
    }
    let parent = parentHeadings.get(heading.depth - 1);
    if (!parent) {
      for (let depth = heading.depth - 1; depth >= 2; depth -= 1) {
        const candidate = parentHeadings.get(depth);
        if (candidate) {
          parent = candidate;
          break;
        }
      }
    }
    if (parent) {
      parent.subheadings.push(heading);
    } else {
      toc.push(heading);
    }
  });
  return toc;
}
---

<details {...detailsAttrs} class="animate group">
  <summary
    class="cursor-pointer py-1.5 text-sm font-medium text-black/70 hover:text-black dark:text-white/70 dark:hover:text-white"
    >Table of Contents</summary
  >
  <nav
    class="max-h-[min(60vh,32rem)] overflow-x-hidden overflow-y-auto pr-2 2xl:max-h-[calc(100dvh-17rem)]"
  >
    <ul class="py-2">
      {toc.map((heading) => <TableOfContentsHeading heading={heading} />)}
    </ul>
  </nav>
</details>

<script is:inline>
  const setActiveTocLink = () => {
    const headings = Array.from(
      document.querySelectorAll("article :is(h2, h3, h4, h5, h6)[id]"),
    );
    const links = Array.from(document.querySelectorAll("[data-toc-link]"));
    if (headings.length === 0 || links.length === 0) return;

    let active = headings[0];
    for (const heading of headings) {
      if (heading.getBoundingClientRect().top <= 140) {
        active = heading;
      } else {
        break;
      }
    }

    for (const link of links) {
      const isActive = link.dataset.tocLink === active.id;
      link.dataset.active = String(isActive);
      if (isActive) {
        link.setAttribute("aria-current", "location");
      } else {
        link.removeAttribute("aria-current");
      }
    }
  };

  setActiveTocLink();
  document.addEventListener("scroll", setActiveTocLink, { passive: true });
  document.addEventListener("astro:page-load", setActiveTocLink);
</script>
