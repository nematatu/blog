---
import type { CollectionEntry } from "astro:content";
import { getOgThumbnailSet } from "@lib/og-thumbnail";

type Props = {
  entry: CollectionEntry<"blog"> | CollectionEntry<"projects">;
};

const { entry } = Astro.props as {
  entry: CollectionEntry<"blog"> | CollectionEntry<"projects">;
};
const ogImage = entry.data.ogImage;
const thumbnail = getOgThumbnailSet(ogImage);
---

<a
  href={`/${entry.collection}/${entry.id}`}
  class="not-prose group relative flex flex-col gap-4 rounded-xl border border-black/15 px-4 py-4 pr-10 transition-colors duration-200 hover:bg-black/5 hover:text-black focus-visible:bg-black/5 focus-visible:text-black sm:flex-row sm:gap-6 dark:border-white/20 dark:hover:bg-white/5 dark:hover:text-white dark:focus-visible:bg-white/5 dark:focus-visible:text-white"
>
  {
    ogImage && (
      <div class="aspect-video w-full shrink-0 overflow-hidden rounded border border-black/10 sm:w-40 dark:border-white/15">
        <img
          src={thumbnail?.src ?? ogImage}
          srcset={thumbnail?.srcset}
          sizes="(min-width: 640px) 10rem, calc(100vw - 2rem)"
          width="480"
          height="270"
          alt=""
          class="h-full w-full object-cover"
          loading="lazy"
          decoding="async"
          aria-hidden="true"
        />
      </div>
    )
  }
  <div class="flex min-w-0 flex-1 flex-col justify-center">
    <div
      class="text-lg leading-tight font-bold transition-colors group-hover:text-blue-600 dark:group-hover:text-blue-400"
    >
      {entry.data.title}
      {
        entry.data.draft && (
          <span class="ml-2 align-middle text-xs font-semibold text-red-600 dark:text-red-400">
            (draft)
          </span>
        )
      }
    </div>
    {
      entry.data.description && (
        <div class="mt-2 line-clamp-2 text-sm text-black/60 dark:text-white/60">
          {entry.data.description}
        </div>
      )
    }
  </div>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    class="absolute top-1/2 right-3 size-5 -translate-y-1/2 fill-none stroke-current stroke-2 transition-transform group-hover:translate-x-1"
  >
    <line x1="5" y1="12" x2="19" y2="12" class="translate-x-0"></line>
    <polyline points="12 5 19 12 12 19" class="translate-x-0"></polyline>
  </svg>
</a>
