---
import type { CollectionEntry } from "astro:content";

type Props = {
  entry: CollectionEntry<"blog"> | CollectionEntry<"projects">;
};

const { entry } = Astro.props as {
  entry: CollectionEntry<"blog"> | CollectionEntry<"projects">;
};
---

<a
  href={`/${entry.collection}/${entry.id}`}
  class="not-prose group relative flex flex-nowrap border border-black/15 px-4 py-3 pr-10 hover:bg-black/5 hover:text-black focus-visible:bg-black/5 focus-visible:text-black dark:border-white/20 dark:hover:bg-white/5 dark:hover:text-white dark:focus-visible:bg-white/5 dark:focus-visible:text-white"
>
  <div class="flex flex-1 flex-col truncate">
    <div class="font-semibold">
      {entry.data.title}
      {
        entry.data.draft && (
          <span class="ml-2 align-middle text-xs font-semibold text-red-600 dark:text-red-400">
            (draft)
          </span>
        )
      }
    </div>
    {
      entry.data.description && (
        <div class="text-sm">{entry.data.description}</div>
      )
    }
  </div>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    class="absolute top-1/2 right-2 size-5 -translate-y-1/2 fill-none stroke-current stroke-2"
  >
    <line x1="5" y1="12" x2="19" y2="12" class="translate-x-0"></line>
    <polyline points="12 5 19 12 12 19" class="translate-x-0"></polyline>
  </svg>
</a>
