<aside data-pagefind-ignore>
  <div
    id="backdrop"
    class="invisible fixed top-0 left-0 z-50 flex h-screen w-full justify-center bg-black/50 p-6 backdrop-blur-xs"
  >
    <div
      id="pagefind-container"
      class="m-0 flex h-fit max-h-[80%] w-full max-w-4xl flex-col overflow-auto border border-black/15 bg-neutral-100 px-4 py-3 dark:border-white/20 dark:bg-neutral-900"
    >
      <div id="search" class="pagefind-ui"></div>
      <div class="dark:prose-invert mr-2 pt-4 pb-1 text-right text-xs">
        Press <span class="prose dark:prose-invert text-xs"><kbd>Esc</kbd></span
        > or click anywhere to close
      </div>
    </div>
  </div>
</aside>

<script is:inline>
  let pagefindReady;
  const backdrop = document.getElementById("backdrop");
  const search = document.getElementById("search");
  const closeSearch = () => backdrop.classList.replace("visible", "invisible");

  const loadPagefind = () =>
    (pagefindReady ??= new Promise((resolve) => {
      document.head.insertAdjacentHTML(
        "beforeend",
        '<link rel="stylesheet" href="/pagefind/pagefind-ui.css">',
      );
      const script = document.createElement("script");
      script.src = "/pagefind/pagefind-ui.js";
      script.onload = resolve;
      document.head.append(script);
    }).then(() => {
      new window.PagefindUI({
        element: "#search",
        bundlePath: "/pagefind/",
        showImages: false,
        excerptLength: 15,
        resetStyles: false,
      });
    }));

  const openSearch = async () => {
    backdrop.classList.replace("invisible", "visible");
    await loadPagefind();
    setTimeout(() => search.querySelector("input")?.focus(), 0);
  };

  document.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof Element)) return;
    if (target.closest("#magnifying-glass")) openSearch();
    if (
      target === backdrop ||
      target.classList.contains("pagefind-ui__result-link")
    ) {
      closeSearch();
    }
  });

  document.addEventListener("keydown", (event) => {
    if (
      event.key === "/" ||
      ((event.metaKey || event.ctrlKey) && event.key === "k")
    ) {
      event.preventDefault();
      openSearch();
    }
    if (event.key === "Escape") closeSearch();
  });

  document.addEventListener("submit", (event) => {
    if (event.target instanceof Element && event.target.closest("#search")) {
      event.preventDefault();
    }
  });
</script>

<style is:global>
  :root {
    --pagefind-ui-scale: 0.75;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 0;
    --pagefind-ui-font: var(--font-sans);
    --pagefind-ui-primary: #3d3d3d;
    --pagefind-ui-text: #3d3d3d;
    --pagefind-ui-background: #ffffff;
    --pagefind-ui-border: #d0d0d0;
    --pagefind-ui-tag: #f5f5f5;
  }

  .dark {
    --pagefind-ui-primary: #d4d4d4;
    --pagefind-ui-text: #d4d4d4;
    --pagefind-ui-background: #171717;
    --pagefind-ui-border: #404040;
  }

  #search :is(input, p) {
    font-weight: normal;
  }

  #search .pagefind-ui__result-title {
    font-weight: 600;
  }

  #search .pagefind-ui__message {
    padding: 0 0 0.75rem;
  }
</style>
