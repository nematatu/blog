---
import type { CollectionEntry } from "astro:content";

type Props = {
  currentId: string;
  posts: CollectionEntry<"blog">[];
};

const { currentId, posts } = Astro.props as Props;
---

<nav aria-label="記事一覧" class="text-sm">
  <div class="mb-3 px-2 text-xs font-medium text-black/45 dark:text-white/45">
    記事
  </div>
  <ol class="space-y-0.5">
    {
      posts.map((post) => {
        const isCurrent = post.id === currentId;

        return (
          <li>
            <a
              href={`/blog/${post.id}`}
              aria-current={isCurrent ? "page" : undefined}
              class:list={[
                "block border-l-2 py-1.5 pr-2 pl-3 leading-snug no-underline",
                isCurrent
                  ? "border-blue-700 font-medium text-blue-800 dark:border-blue-400 dark:text-blue-400"
                  : "border-transparent text-black/60 hover:border-black/20 hover:text-black focus-visible:border-black/20 focus-visible:text-black dark:text-white/55 dark:hover:border-white/25 dark:hover:text-white dark:focus-visible:border-white/25 dark:focus-visible:text-white",
              ]}
            >
              {post.data.title}
            </a>
          </li>
        );
      })
    }
  </ol>
</nav>
