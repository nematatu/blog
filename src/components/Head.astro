---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = "", image } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/x-icon" href="/icon/favicon.ico" />
<link rel="apple-touch-icon" href="/icon/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
<meta name="generator" content={Astro.generator} />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=LINE+Seed+JP:wght@400;700&display=swap"
/>
<link rel="preconnect" href="https://assets.blog.amatatu.com" crossorigin />
<link rel="dns-prefetch" href="https://assets.blog.amatatu.com" />
<script async src="https://platform.twitter.com/widgets.js" charset="utf-8"
></script>
<script
  defer
  src="https://code.iconify.design/iconify-icon/2.1.0/iconify-icon.min.js"
></script>
<script
  is:inline
  defer
  src="https://unpkg.com/budoux@0.8.4/bundle/budoux-ja.min.js"></script>

<link rel="canonical" href={canonicalURL} />
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
{image && <meta property="og:image" content={new URL(image, Astro.url)} />}
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
{image && <meta property="twitter:image" content={new URL(image, Astro.url)} />}

<script is:inline>
  const root = document.documentElement;
  const theme = localStorage.theme;
  root.classList.toggle("dark", theme !== "light");
  if (!theme) localStorage.theme = "dark";

  const setTheme = (nextTheme) => {
    localStorage.theme = nextTheme;
    root.classList.toggle(
      "dark",
      nextTheme === "dark" ||
        (nextTheme === "system" &&
          matchMedia("(prefers-color-scheme: dark)").matches),
    );
    document
      .querySelectorAll("[data-theme-button]")
      .forEach((button) =>
        ["bg-black/5", "dark:bg-white/5"].forEach((className) =>
          button.classList.toggle(
            className,
            button.dataset.themeButton === nextTheme,
          ),
        ),
      );

    const giscus = document.querySelector(".giscus-frame");
    if (giscus) {
      const url = new URL(giscus.src);
      url.searchParams.set(
        "theme",
        root.classList.contains("dark") ? "dark" : "light",
      );
      giscus.src = url.toString();
    }
  };

  const copyIcon = (copied) =>
    `<iconify-icon icon="lucide:${copied ? "check" : "copy"}" aria-hidden="true"></iconify-icon>`;

  addEventListener("DOMContentLoaded", () => {
    setTheme(localStorage.theme);
    root.classList.toggle("scrolled", scrollY > 0);

    document.addEventListener("scroll", () =>
      root.classList.toggle("scrolled", scrollY > 0),
    );

    document.addEventListener("click", async (event) => {
      const target = event.target.closest?.("button,a,img");
      if (!target) return;

      if (target.id === "back-to-top") {
        event.preventDefault();
        scrollTo({ top: 0, behavior: "auto" });
      }
      if (target.id === "back-to-prev") history.back();
      if (target.dataset.themeButton) setTheme(target.dataset.themeButton);
      if (target.dataset.copyCode) {
        await navigator.clipboard.writeText(target.closest("pre").innerText);
        target.innerHTML = copyIcon(true);
        setTimeout(() => (target.innerHTML = copyIcon(false)), 2000);
      }
      if (target.matches("article img:not(.fuki__icon)")) openLightbox(target);
    });

    for (const codeBlock of document.querySelectorAll("pre")) {
      const button = document.createElement("button");
      button.className = "copy-code";
      button.type = "button";
      button.dataset.copyCode = "true";
      button.innerHTML = copyIcon(false);
      button.title = "Copy code";
      codeBlock.tabIndex = 0;

      const wrapper = document.createElement("div");
      wrapper.className = "code-block-wrapper";
      codeBlock.before(wrapper);

      if (codeBlock.dataset.filename) {
        wrapper.innerHTML = `<div class="code-block-header"><span class="code-filename">${codeBlock.dataset.filename}</span></div>`;
        wrapper.firstElementChild.append(button);
      } else {
        codeBlock.append(button);
      }
      wrapper.append(codeBlock);
    }

    for (const image of document.querySelectorAll(
      "article img:not(.fuki__icon)",
    )) {
      image.tabIndex = 0;
      image.role = "button";
    }
  });

  function openLightbox(image) {
    let lightbox = document.querySelector(".image-lightbox");
    if (!lightbox) {
      lightbox = document.createElement("div");
      lightbox.className = "image-lightbox";
      lightbox.innerHTML = `<button class="image-lightbox__close" type="button" aria-label="Close image preview"><iconify-icon icon="lucide:x" aria-hidden="true"></iconify-icon></button><img class="image-lightbox__image" alt="" />`;
      lightbox.addEventListener("click", (event) => {
        if (event.target === lightbox || event.target.closest("button")) {
          lightbox.classList.remove("is-open");
          root.classList.remove("image-lightbox-open");
        }
      });
      document.body.append(lightbox);
    }

    const preview = lightbox.querySelector("img");
    preview.src = image.currentSrc || image.src;
    preview.alt = image.alt || "";
    lightbox.classList.add("is-open");
    root.classList.add("image-lightbox-open");
  }
</script>
